        {
          "name": "Log In Job Seeker",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.expect(pm.response.code).to.eql(200);",
                  "});",
                  "",
                  "try {",
                  "  const response = pm.response.json();",
                  "  const container = response.jobseeker || response.data || response;",
                  "  const token = container && (container.token || container.accessToken || container.jwt);",
                  "  if (token) {",
                  "    pm.collectionVariables.set('authToken', token);",
                  "  }",
                  "  if (container && container.id !== undefined && container.id !== null) {",
                  "    pm.collectionVariables.set('currentUserId', String(container.id));",
                  "  }",
                  "  if (container && container.role) {",
                  "    pm.collectionVariables.set('currentUserRole', container.role);",
                  "  }",
                  "} catch (error) {",
                  "  console.warn('Could not parse login response for token extraction', error);",
                  "}"
                ]
              }
            }
          ],
