{
  "compilerOptions": {
    "target": "es2020",
    "module": "nodenext",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types"]
  },
  "include": ["src", "src/prisma.config.ts"],
  "exclude": ["node_modules", "dist"]
}
